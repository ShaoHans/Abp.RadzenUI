@page "/operations/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(CRMPermissions.Operations.Dashboard)]
@inject IOperationAppService OperationAppService
@inherits AbpRadzenUIComponentBase

<PageTitle>@L["OperationsDashboard"]</PageTitle>

@if (_data is null)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height:50vh;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else
{
    <RadzenStack Gap="1rem" class="rz-p-4">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem" Wrap="FlexWrap.Wrap">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.H5"><strong>@L["OperationsDashboard"]</strong></RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-on-surface-variant">@L["OperationsDashboardSubtitle"]</RadzenText>
            </RadzenStack>
            <RadzenButton Icon="refresh" Text="@L["Refresh"]" ButtonStyle="ButtonStyle.Light" Click="LoadAsync" />
        </RadzenStack>

        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="6" SizeXL="3">
                <RadzenCard class="rz-shadow-2" Style="border-left:4px solid #2563eb;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenIcon Icon="fact_check" Style="font-size:2.2rem;color:#2563eb;" />
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Caption">@L["Operation:TotalWorkOrders"]</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4">@_data.TotalWorkOrders</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6" SizeXL="3">
                <RadzenCard class="rz-shadow-2" Style="border-left:4px solid #f59e0b;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenIcon Icon="pending_actions" Style="font-size:2.2rem;color:#f59e0b;" />
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Caption">@L["Operation:OpenWorkOrders"]</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4">@_data.OpenWorkOrders</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6" SizeXL="3">
                <RadzenCard class="rz-shadow-2" Style="border-left:4px solid #dc2626;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenIcon Icon="priority_high" Style="font-size:2.2rem;color:#dc2626;" />
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Caption">@L["Operation:CriticalWorkOrders"]</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4">@_data.CriticalWorkOrders</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6" SizeXL="3">
                <RadzenCard class="rz-shadow-2" Style="border-left:4px solid #16a34a;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenIcon Icon="health_and_safety" Style="font-size:2.2rem;color:#16a34a;" />
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Caption">@L["Operation:AverageHealth"]</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4">@_data.AverageHealthScore</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeLG="7">
                <RadzenCard class="rz-shadow-2">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3">@L["Operation:SevenDayTrend"]</RadzenText>
                    <RadzenChart Style="height:320px;">
                        <RadzenLineSeries Data="@_data.LastSevenDays" CategoryProperty="Name" ValueProperty="Value" Title="@L["Operation:NewWorkOrders"]" Smooth="true" Stroke="#2563eb">
                            <RadzenMarkers MarkerType="MarkerType.Circle" Size="5" />
                        </RadzenLineSeries>
                        <RadzenCategoryAxis />
                        <RadzenValueAxis>
                            <RadzenGridLines Visible="true" />
                        </RadzenValueAxis>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                    </RadzenChart>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeLG="5">
                <RadzenCard class="rz-shadow-2">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3">@L["Operation:StatusDistribution"]</RadzenText>
                    <RadzenChart Style="height:320px;">
                        <RadzenPieSeries Data="@_data.WorkOrdersByStatus" CategoryProperty="Name" ValueProperty="Value">
                            <RadzenSeriesDataLabels Visible="true" />
                        </RadzenPieSeries>
                        <RadzenLegend Position="LegendPosition.Right" />
                    </RadzenChart>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeLG="6">
                <RadzenCard class="rz-shadow-2">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3">@L["Operation:PriorityDistribution"]</RadzenText>
                    <RadzenChart Style="height:300px;">
                        <RadzenColumnSeries Data="@_data.WorkOrdersByPriority" CategoryProperty="Name" ValueProperty="Value" Title="@L["Operation:WorkOrders"]" Fill="#f59e0b" />
                        <RadzenCategoryAxis />
                        <RadzenValueAxis>
                            <RadzenGridLines Visible="true" />
                        </RadzenValueAxis>
                    </RadzenChart>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeLG="6">
                <RadzenCard class="rz-shadow-2">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3">@L["Operation:AssetHealthBands"]</RadzenText>
                    <RadzenChart Style="height:300px;">
                        <RadzenColumnSeries Data="@_data.AssetHealthBands" CategoryProperty="Name" ValueProperty="Value" Title="@L["Operation:Assets"]" Fill="#0f766e" />
                        <RadzenCategoryAxis />
                        <RadzenValueAxis>
                            <RadzenGridLines Visible="true" />
                        </RadzenValueAxis>
                    </RadzenChart>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenStack>
}

@code {
    private OperationDashboardDto? _data;

    public Dashboard()
    {
        LocalizationResource = typeof(CRMResource);
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _data = await OperationAppService.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            await HandleErrorAsync(ex);
        }
    }
}
