<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>Abp.RadzenUI</RootNamespace>
		<PackageId>AbpRadzen.Domain</PackageId>
		<Authors>ShaoHans</Authors>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageDescription>Domain entities for ABP RadzenUI</PackageDescription>
		<RepositoryUrl>https://github.com/ShaoHans/Abp-RadzenUI</RepositoryUrl>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="." />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Abp.RadzenUI.Domain.Shared\Abp.RadzenUI.Domain.Shared.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Volo.Abp.Caching" />
		<PackageReference Include="Volo.Abp.AuditLogging.Domain" />
		<PackageReference Include="Volo.Abp.FeatureManagement.Domain" />
		<PackageReference Include="Volo.Abp.SettingManagement.Domain" />
		<PackageReference Include="Volo.Abp.Identity.Domain" />
		<PackageReference Include="Volo.Abp.TenantManagement.Domain" />
	</ItemGroup>

</Project>