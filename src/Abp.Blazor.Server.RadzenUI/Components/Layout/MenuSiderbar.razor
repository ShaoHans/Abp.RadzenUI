@using Abp.RadzenUI.Navigation
@using Abp.RadzenUI.UIPlaceHolders
@using Volo.Abp.UI.Navigation
@implements IAsyncDisposable
@inject IMenuManager MenuManager
@inject IEnumerable<IMenuItemDecorationContributor> MenuItemDecorationContributors
@inject NavigationManager NavigationManager
@inject MenuItemDecorationState MenuItemDecorationState

<RadzenSidebar Responsive="true"
               @bind-Expanded="@SidebarExpanded"
               class="demos-sidebar"
               style="display: flex; flex-direction: column; --rz-sidebar-width: clamp(14rem, 13.5rem + 0.6vw, 15rem);">
    @* <div style="padding: 1rem">
        <RadzenTextBox id="find" Placeholder="Find menu ..." type="search" @oninput="@FilterPanelMenu" style="width: 100%" class="rz-search-input" aria-label="find" />
    </div> *@
    <div style="flex: 1; overflow: auto">
        <RadzenPanelMenu Match="NavLinkMatch.Prefix" Multiple="@_titleBarSettings.AllowSideMenuMultipleExpand"
                         Style="--rz-panel-menu-icon-margin-inline: 0 0.75rem; --rz-panel-menu-item-padding: 0.75rem 0.875rem; --rz-panel-menu-item-2nd-level-padding: 0.625rem 0.875rem 0.625rem 2.5rem; --rz-panel-menu-item-3rd-level-padding: 0.5rem 0.875rem 0.5rem 3rem;">
            @foreach (var menu in _applicationMenu?.Items ?? [])
            {
                @BuildMenuTree(menu);
            }
        </RadzenPanelMenu>
    </div>
</RadzenSidebar>

@code {
    [Parameter] public bool SidebarExpanded { get; set; }
    [Parameter] public EventCallback<bool> SidebarExpandedChanged { get; set; }
    [Inject] IUIPlaceHolderResolver UIPlaceHolderResolver { get; set; } = default!;
    TitleBarSettings _titleBarSettings = new();
    readonly Dictionary<string, MenuItemDecorationContext> _menuItemDecorations = [];


    ApplicationMenu _applicationMenu = default!;

    protected override async Task OnInitializedAsync()
    {
        _applicationMenu = await MenuManager.GetMainMenuAsync();
        _titleBarSettings = await UIPlaceHolderResolver.GetTitleBarSettingsAsync();
        await ReloadMenuDecorationsAsync();

        NavigationManager.LocationChanged += OnLocationChanged;
        MenuItemDecorationState.Changed += HandleDecorationsChangedAsync;
    }

    void FilterPanelMenu(ChangeEventArgs args)
    {
        var term = args.Value?.ToString();
    }

    RenderFragment BuildMenuTree(ApplicationMenuItem menuItem) => __builder =>
    {
        var displayName = GetDisplayName(menuItem);

        <RadzenPanelMenuItem aria-label="@menuItem.Name"
                             Icon="@menuItem.Icon"
                             IconColor="@GetIconColor(menuItem)"
                             Text="@displayName"
                             Path="@menuItem.Url"
                             Template="@(UseTemplate(menuItem) ? BuildMenuTemplate(menuItem) : null)"
                             ChildContent="@(menuItem.Items.IsNullOrEmpty() ? null : BuildMenuChildren(menuItem.Items))" />
    };

    RenderFragment BuildMenuChildren(IReadOnlyList<ApplicationMenuItem> menuItems) => __builder =>
    {
        foreach (var child in menuItems)
        {
            @BuildMenuTree(child)
        }
    };

    async Task ReloadMenuDecorationsAsync()
    {
        _menuItemDecorations.Clear();

        if (_applicationMenu is null)
        {
            return;
        }

        await LoadMenuDecorationsAsync(_applicationMenu.Items);
    }

    async Task ReloadMenuDecorationsAsync(IReadOnlyCollection<string> refreshKeys)
    {
        if (_applicationMenu is null)
        {
            return;
        }

        if (refreshKeys.Count == 0)
        {
            await ReloadMenuDecorationsAsync();
            return;
        }

        foreach (var menuItem in EnumerateMenuItems(_applicationMenu.Items))
        {
            var decoration = GetDecoration(menuItem);

            if (decoration is null || decoration.RefreshKeys.Overlaps(refreshKeys))
            {
                _menuItemDecorations[menuItem.Name] = await BuildMenuDecorationAsync(menuItem);
            }
        }
    }

    async Task LoadMenuDecorationsAsync(IReadOnlyList<ApplicationMenuItem> menuItems)
    {
        foreach (var menuItem in menuItems)
        {
            _menuItemDecorations[menuItem.Name] = await BuildMenuDecorationAsync(menuItem);

            if (!menuItem.Items.IsNullOrEmpty())
            {
                await LoadMenuDecorationsAsync(menuItem.Items);
            }
        }
    }

    async Task<MenuItemDecorationContext> BuildMenuDecorationAsync(ApplicationMenuItem menuItem)
    {
        var context = new MenuItemDecorationContext(menuItem);

        foreach (var contributor in MenuItemDecorationContributors)
        {
            await contributor.ConfigureAsync(context);
        }

        return context;
    }

    static IEnumerable<ApplicationMenuItem> EnumerateMenuItems(IReadOnlyList<ApplicationMenuItem> menuItems)
    {
        foreach (var menuItem in menuItems)
        {
            yield return menuItem;

            if (!menuItem.Items.IsNullOrEmpty())
            {
                foreach (var child in EnumerateMenuItems(menuItem.Items))
                {
                    yield return child;
                }
            }
        }
    }

    string GetDisplayName(ApplicationMenuItem menuItem)
    {
        return GetDecoration(menuItem)?.DisplayName ?? menuItem.DisplayName;
    }

    string? GetIconColor(ApplicationMenuItem menuItem)
    {
        return GetDecoration(menuItem)?.IconColor ?? menuItem.GetIconColor();
    }

    bool UseTemplate(ApplicationMenuItem menuItem)
    {
        return GetDecoration(menuItem)?.HasVisibleBadges == true;
    }

    MenuItemDecorationContext? GetDecoration(ApplicationMenuItem menuItem)
    {
        return _menuItemDecorations.GetValueOrDefault(menuItem.Name);
    }

    RenderFragment BuildMenuTemplate(ApplicationMenuItem menuItem) => __builder =>
    {
        var decoration = GetDecoration(menuItem);
        var displayName = decoration?.DisplayName ?? menuItem.DisplayName;

        @displayName
        @if (decoration is not null)
        {
            foreach (var badge in decoration.Badges.Where(static badge => badge.Visible).OrderBy(badge => badge.Order))
            {
                <RadzenBadge Text="@badge.Text"
                             BadgeStyle="@badge.BadgeStyle"
                             Style="@badge.Style" />
            }
        }
    };

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await ReloadMenuDecorationsAsync();
            StateHasChanged();
        });
    }

    async Task HandleDecorationsChangedAsync(MenuItemDecorationChange change)
    {
        await ReloadMenuDecorationsAsync(change.RefreshKeys);
        await InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        MenuItemDecorationState.Changed -= HandleDecorationsChangedAsync;
        return ValueTask.CompletedTask;
    }
}
