@using Abp.RadzenUI.Localization
@inherits AbpRadzenUIComponentBase

<RadzenSidebar Responsive="false"
               @bind-Expanded="@SidebarExpanded"
               class="rz-sidebar-second"
               Style="--rz-sidebar-width: min(420px, calc(100vw - 0.5rem)); grid-area: rz-config-sidebar; background-color: var(--rz-body-background-color); color: var(--rz-text-color);">
    <RadzenStack class="rz-p-4" Gap="0.75rem" Style="height:100%; min-height:0;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenText TextStyle="TextStyle.H6" TagName="TagName.H2" class="rz-m-0">@L["Message:MyMessages"]</RadzenText>
            <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Click="CloseSidebarAsync" />
        </RadzenStack>

        <div style="flex:1; min-height:0; overflow:hidden;">
            @if (SidebarExpanded && CurrentUser.IsAuthenticated)
            {
                <MessageInboxPanel IsOpen="@SidebarExpanded" NavigateToListRequested="CloseSidebarAsync" />
            }
        </div>
    </RadzenStack>
</RadzenSidebar>

@code {
    [Parameter]
    public bool SidebarExpanded { get; set; }

    [Parameter]
    public EventCallback<bool> SidebarExpandedChanged { get; set; }

    public MessageSidebar()
    {
        LocalizationResource = typeof(AbpRadzenUIResource);
    }

    private Task CloseSidebarAsync()
    {
        SidebarExpanded = false;
        return SidebarExpandedChanged.InvokeAsync(false);
    }
}