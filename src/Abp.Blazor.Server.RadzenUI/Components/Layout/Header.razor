@using Abp.RadzenUI.Avatar
@using Abp.RadzenUI.LinkAccounts
@using Abp.RadzenUI.LinkAccounts.Dtos
@using Abp.RadzenUI.UIPlaceHolders
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using Volo.Abp.Account.Localization
@using Volo.Abp.AspNetCore.Components
@using Volo.Abp.Data
@using Volo.Abp.Identity
@using Volo.Abp.UI.Navigation
@implements IAsyncDisposable
@inherits AbpRadzenUIComponentBase
@inject IStringLocalizer<AbpRadzenUIResource> TL
@inject IIdentityUserRepository IdentityUserRepository
@inject ILinkedAccountAppService LinkedAccountAppService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime
@inject IMenuManager MenuManager
@inject NavigationManager NavigationManager

<style>
    /* GitHub-style icon buttons with rounded border box */
    .app-header__actions .app-header__icon-action {
        width: 2rem !important;
        height: 2rem !important;
        min-width: unset !important;
        min-height: unset !important;
        padding: 0 !important;
        margin: 0 !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        border: 1px solid color-mix(in srgb, currentColor 25%, transparent) !important;
        border-radius: 0.375rem !important;
        background: transparent !important;
        color: inherit !important;
        cursor: pointer;
        transition: background-color 0.15s ease, border-color 0.15s ease;
        box-sizing: border-box;
        text-decoration: none;
    }
    .app-header__actions .app-header__icon-action:hover {
        background: color-mix(in srgb, currentColor 8%, transparent) !important;
        border-color: color-mix(in srgb, currentColor 40%, transparent) !important;
    }
    /* Sidebar-toggle overrides */
    .app-header__actions .rz-sidebar-toggle.app-header__icon-action {
        border-inline-end: 1px solid color-mix(in srgb, currentColor 25%, transparent) !important;
        margin-inline-end: 0 !important;
    }
    /* Button icon margin reset */
    .app-header__actions .app-header__icon-action .rz-button-icon-left {
        margin: 0 !important;
    }
    .app-header__actions .app-header__icon-action .rzi {
        font-size: 1.125rem !important;
    }
    /* Active state (e.g. fullscreen active) */
    .app-header__actions .app-header__icon-action--active {
        color: var(--rz-primary) !important;
        border-color: var(--rz-primary) !important;
    }
    /* Language menu: icon-only box */
    .app-header__actions .app-header__menu--language {
        margin: 0 !important;
        padding: 0 !important;
        background: transparent !important;
    }
    .app-header__actions .app-header__menu--language > li > .rz-navigation-item-wrapper > .rz-navigation-item-link {
        padding: 0 !important;
        width: 2rem !important;
        height: 2rem !important;
        min-height: unset !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        border: 1px solid color-mix(in srgb, currentColor 25%, transparent) !important;
        border-radius: 0.375rem !important;
        background: transparent !important;
        gap: 0 !important;
        box-sizing: border-box;
        transition: background-color 0.15s ease, border-color 0.15s ease;
    }
    .app-header__actions .app-header__menu--language > li > .rz-navigation-item-wrapper > .rz-navigation-item-link:hover {
        background: color-mix(in srgb, currentColor 8%, transparent) !important;
        border-color: color-mix(in srgb, currentColor 40%, transparent) !important;
    }
    .app-header__actions .app-header__menu--language .rz-navigation-item-icon-children {
        display: none !important;
    }
    .app-header__actions .app-header__menu--language .rz-navigation-item-link .rzi {
        font-size: 1.125rem !important;
    }
    /* Profile menu: compact */
    .app-header__actions .rz-profile-menu {
        margin: 0 !important;
        background: transparent !important;
    }
    .app-header__actions .rz-profile-menu > li > .rz-navigation-item-wrapper > .rz-navigation-item-link {
        padding: 0 0.25rem !important;
        min-height: 2rem !important;
        gap: 0 !important;
    }
    .app-header__actions .rz-profile-menu > li > .rz-navigation-item-wrapper > .rz-navigation-item-link > .rz-navigation-item-icon-children {
        display: none !important;
    }
    /* Sidebar-width toggle area */
    .app-header__sidebar-area {
        min-width: clamp(14rem, 13.5rem + 0.6vw, 15rem);
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }
    /* Breadcrumb in header */
    .app-header__breadcrumb {
        display: inline-flex;
        align-items: center;
        overflow: hidden;
    }
    .app-header__breadcrumb .rz-breadcrumb {
        flex-wrap: nowrap;
        padding: 0;
        gap: 0;
    }
    .app-header__breadcrumb .rz-breadcrumb-item {
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
    }
    .app-header__breadcrumb .rz-breadcrumb-item + .rz-breadcrumb-item::before {
        content: ">" !important;
        margin: 0 0.375rem;
        opacity: 0.6;
    }
    .app-header__breadcrumb .rz-breadcrumb-item .rzi {
        font-size: 1.125rem !important;
    }
    .app-header__breadcrumb .rz-breadcrumb-item .rz-label {
        font-size: 0.875rem;
    }
</style>

<RadzenHeader class="app-header">
    <ChildContent>
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Start" Gap="0px" class="app-header__row">
            <RadzenColumn Size="8">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="app-header__title">
                    <div class="app-header__sidebar-area">
                        <RadzenSidebarToggle Click="@MenuToggle" />
                        <span class="app-header__title-text" style="overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">@_titleBar.Title</span>
                    </div>
                    @if (_titleBar.ShowBreadcrumb && _breadcrumbItems.Count > 0)
                    {
                        <RadzenButton Icon="refresh" title="Refresh" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                                      class="app-header__icon-action" Click="@RefreshPage" Style="margin-inline-end: 0.25rem;" />
                        <div class="app-header__breadcrumb">
                            <RadzenBreadCrumb>
                                @for (var i = 0; i < _breadcrumbItems.Count; i++)
                                {
                                    var item = _breadcrumbItems[i];
                                    var isLast = i == _breadcrumbItems.Count - 1;
                                    <RadzenBreadCrumbItem Text="@item.DisplayName" Icon="@item.Icon"
                                                          Path="@(isLast ? null : item.Url)" />
                                }
                            </RadzenBreadCrumb>
                        </div>
                    }
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" JustifyContent="JustifyContent.End" class="app-header__actions">
                    @if (_titleBar.ShowGithubLink)
                    {
                        <a href="https://github.com/ShaoHans/Abp-RadzenUI"
                           title="Star Abp-RadzenUI on GitHub"
                           target="_blank"
                           class="app-header__action app-header__icon-action app-header__action--github"
                           style="color: inherit; text-decoration: none;">
                            <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" style="display:block;">
                                <path d="M10.226 17.284c-2.965-.36-5.054-2.493-5.054-5.256 0-1.123.404-2.336 1.078-3.144-.292-.741-.247-2.314.09-2.965.898-.112 2.111.36 2.83 1.01.853-.269 1.752-.404 2.853-.404 1.1 0 1.999.135 2.807.382.696-.629 1.932-1.1 2.83-.988.315.606.36 2.179.067 2.942.72.854 1.101 2 1.101 3.167 0 2.763-2.089 4.852-5.098 5.234.763.494 1.28 1.572 1.28 2.807v2.336c0 .674.561 1.056 1.235.786 4.066-1.55 7.255-5.615 7.255-10.646C23.5 6.188 18.334 1 11.978 1 5.62 1 .5 6.188.5 12.545c0 4.986 3.167 9.12 7.435 10.669.606.225 1.19-.18 1.19-.786V20.63a2.9 2.9 0 0 1-1.078.224c-1.483 0-2.359-.808-2.987-2.313-.247-.607-.517-.966-1.034-1.033-.27-.023-.359-.135-.359-.27 0-.27.45-.471.898-.471.652 0 1.213.404 1.797 1.235.45.651.921.943 1.483.943.561 0 .92-.202 1.437-.719.382-.381.674-.718.944-.943"></path>
                            </svg>
                        </a>
                    }
                    <RadzenAppearanceToggle class="app-header__action app-header__icon-action" />
                    <RadzenSidebarToggle Icon="settings" Click="@ThemeToggle" class="app-header__action app-header__icon-action" />
                    <RadzenButton Icon="@(_isFullscreen ? "fullscreen_exit" : "fullscreen")"
                                  title="@(_isFullscreen ? "Exit full screen" : "Full screen")"
                                  Variant="Variant.Text"
                                  ButtonStyle="ButtonStyle.Base"
                                  class="@GetFullscreenButtonClass()"
                                  Click="@ToggleFullscreenAsync" />
                    @if (_titleBar.ShowLanguageMenu)
                    {
                        <div class="app-header__action">
                            <LanguageSwitch />
                        </div>
                    }
                    @if (CurrentUser != null && CurrentUser.IsAuthenticated)
                    {
                        <div class="app-header__action">
                            <RadzenProfileMenu class="app-header__profile">
                                <Template>
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="app-header__profile-trigger">
                                        @if (_avatarUrl.IsNullOrWhiteSpace())
                                        {
                                            <RadzenGravatar Email="@CurrentUser.Email" Style="width:24px;height:24px;"></RadzenGravatar>
                                        }
                                        else
                                        {
                                            <img src="@_avatarUrl" alt="@CurrentUser.UserName" class="avatar-header-image" />
                                        }
                                        @* <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0 rz-display-none rz-display-md-block" Style="line-height: 1; color: inherit;">@CurrentUser.UserName</RadzenText> *@
                                    </RadzenStack>
                                </Template>
                                <ChildContent>
                                    <RadzenProfileMenuItem Text="@CurrentUser.UserName"></RadzenProfileMenuItem>
                                    <Devider />
                                    <RadzenProfileMenuItem Text="@TL["LinkedAccounts:Title"]" Icon="link" Path="/account/linked-accounts"></RadzenProfileMenuItem>
                                    @if (_linkedAccountSession?.CanGoBack == true)
                                    {
                                        <RadzenProfileMenuItem Text="@TL["LinkedAccounts:BackToPreviousAccount"]" Icon="undo" Path="@GetBackPath()"></RadzenProfileMenuItem>
                                    }
                                    <RadzenProfileMenuItem Text="@L["MyAccount"]" Icon="person" Path="/account/manage"></RadzenProfileMenuItem>
                                    <RadzenProfileMenuItem Text="@L["LoggedOutTitle"]" Icon="logout" Path="/account/logout"></RadzenProfileMenuItem>
                                </ChildContent>
                            </RadzenProfileMenu>
                        </div>
                    }
                    else
                    {
                        <div class="rz-display-none rz-display-sm-inline-flex align-items-center app-header__action">
                            <RadzenLink Path="/account/login" Text="@TL["Login"]" class="rz-text-nowrap app-header__link" />
                        </div>
                    }
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </ChildContent>
</RadzenHeader>

@code {
    [Parameter] public EventCallback<EventArgs> MenuToggle { get; set; }
    [Parameter] public EventCallback<EventArgs> ThemeToggle { get; set; }
    [Inject] IUIPlaceHolderResolver UIPlaceHolderResolver { get; set; } = default!;
    TitleBarSettings _titleBar = new();
    string? _avatarUrl;
    bool _isFullscreen;
    DotNetObjectReference<Header>? _dotNetReference;
    List<ApplicationMenuItem> _breadcrumbItems = new();
    ApplicationMenu? _applicationMenu;
    LinkedAccountSessionDto? _linkedAccountSession;

    public Header()
    {
        LocalizationResource = typeof(AccountResource);
    }

    protected override async Task OnInitializedAsync()
    {
        _titleBar = await UIPlaceHolderResolver.GetTitleBarSettingsAsync();
        _applicationMenu = await MenuManager.GetMainMenuAsync();
        UpdateBreadcrumb();
        NavigationManager.LocationChanged += OnLocationChanged;

        if (CurrentUser.IsAuthenticated && CurrentUser.Id.HasValue)
        {
            var user = await IdentityUserRepository.GetAsync(CurrentUser.Id.Value);
            _avatarUrl = user.GetProperty<string>(AvatarConsts.ExtraPropertyName);
            _linkedAccountSession = await LinkedAccountAppService.GetCurrentSessionAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetReference = DotNetObjectReference.Create(this);
        _isFullscreen = await JSRuntime.InvokeAsync<bool>(
            "abpRadzenFullscreen.initialize",
            _dotNetReference
        );
        await InvokeAsync(StateHasChanged);
    }

    async Task ToggleFullscreenAsync()
    {
        _isFullscreen = await JSRuntime.InvokeAsync<bool>("abpRadzenFullscreen.toggle");
    }

    string GetFullscreenButtonClass()
    {
        return _isFullscreen
            ? "app-header__action app-header__icon-action app-header__icon-action--active"
            : "app-header__action app-header__icon-action";
    }

    [JSInvokable]
    public async Task HandleFullscreenChange(bool isFullscreen)
    {
        _isFullscreen = isFullscreen;
        await InvokeAsync(StateHasChanged);
    }

    void RefreshPage()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    string GetBackPath()
    {
        return $"/account/linked-accounts/back?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}";
    }

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateBreadcrumb();
        InvokeAsync(StateHasChanged);
    }

    void UpdateBreadcrumb()
    {
        _breadcrumbItems.Clear();
        if (_applicationMenu == null) return;

        var currentPath = "/" + NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimStart('/');

        foreach (var menuItem in _applicationMenu.Items)
        {
            var trail = new List<ApplicationMenuItem>();
            if (FindMenuPath(menuItem, currentPath, trail))
            {
                _breadcrumbItems = trail;
                return;
            }
        }
    }

    bool FindMenuPath(ApplicationMenuItem item, string currentPath, List<ApplicationMenuItem> trail)
    {
        trail.Add(item);

        var itemUrl = item.Url?.TrimEnd('/') ?? "";
        if (!string.IsNullOrEmpty(itemUrl) && string.Equals(itemUrl, currentPath.TrimEnd('/'), StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        foreach (var child in item.Items)
        {
            if (FindMenuPath(child, currentPath, trail))
            {
                return true;
            }
        }

        trail.RemoveAt(trail.Count - 1);
        return false;
    }

    public async ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;

        if (_dotNetReference is null)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("abpRadzenFullscreen.dispose");
        }
        catch (JSDisconnectedException)
        {
        }

        _dotNetReference.Dispose();
        _dotNetReference = null;
    }
}
