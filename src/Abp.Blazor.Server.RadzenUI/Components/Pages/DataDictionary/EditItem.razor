@using Abp.RadzenUI.Application.Contracts.DataDictionaries
@using Abp.RadzenUI.DataDictionaries
@using Volo.Abp.AspNetCore.Components
@inherits AbpRadzenUIComponentBase

<RadzenTemplateForm TItem="UpdateDataDictionaryItemDto" Data=@DialogFromOption.Model Submit="@(model => DialogFromOption.SubmitAsync(model, () => InvokeAsync(StateHasChanged)))"
                    Style="max-height:calc(100vh - 200px); display: flex; flex-direction:column">
    <DialogFormLayout CancelClick="DialogFromOption.OnCancel" IsSaving="@DialogFromOption.IsSaving">
        <RadzenStack Gap="2rem" class="rz-p-4 rz-p-md-12">
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-start rz-text-align-md-end">
                    <RadzenLabel Text="@L["DataDictionary:Types"]" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:700; display:block; width:100%; padding-top:0.5rem;">
                        @TypeDisplayText
                    </RadzenText>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-start rz-text-align-md-end">
                    <RadzenLabel Text="@L["DisplayName:DataDictionaryItem.Code"]" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:700; display:block; width:100%; padding-top:0.5rem;">
                        @Code
                    </RadzenText>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-start rz-text-align-md-end">
                    <RequiredMark />
                    <RadzenLabel Text="@L["DisplayName:DataDictionaryItem.Name"]" Component="Name" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenTextBox Name="Name" @bind-Value=@DialogFromOption.Model.Name
                                   Style="display: block; width: 100%;"
                                   MaxLength="DataDictionaryItemConsts.MaxNameLength" />
                    <RadzenRequiredValidator Component="Name" Text="@L.Required("DisplayName:DataDictionaryItem.Name")" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-start rz-text-align-md-end">
                    <RadzenLabel Text="@L["DisplayName:DataDictionaryItem.Sort"]" Component="Sort" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenNumeric Name="Sort" TValue="int" @bind-Value=@DialogFromOption.Model.Sort
                                   Style="display: block; width: 100%;" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-start rz-text-align-md-end">
                    <RadzenLabel Text="@L["DisplayName:DataDictionaryItem.IsActive"]" Component="IsActive" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenSwitch Name="IsActive" @bind-Value=@DialogFromOption.Model.IsActive />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-start rz-text-align-md-end">
                    <RadzenLabel Text="@L["DisplayName:DataDictionaryItem.Description"]" Component="Description" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenTextArea Name="Description" @bind-Value=@DialogFromOption.Model.Description
                                    Style="display: block; width: 100%;" Rows="3"
                                    MaxLength="DataDictionaryItemConsts.MaxDescriptionLength" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </DialogFormLayout>
</RadzenTemplateForm>

@code {
    [Parameter]
    public DialogFromOption<UpdateDataDictionaryItemDto> DialogFromOption { get; set; } = default!;

    [Parameter]
    public string TypeDisplayText { get; set; } = string.Empty;

    [Parameter]
    public string Code { get; set; } = string.Empty;

    public EditItem()
    {
        LocalizationResource = typeof(AbpRadzenUIResource);
    }
}
